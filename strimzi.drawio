<mxfile host="app.diagrams.net" modified="2026-06-23T00:00:00.000Z" agent="ChatGPT" version="24.7.17" type="device">
  <diagram id="strimzi-cdc-flow" name="Strimzi CDC Platform Flow">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Strimzi 기반 CDC 플랫폼 구성 흐름도&lt;br&gt;Oracle → Kafka → PostgreSQL" style="text;html=1;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="260" y="20" width="760" height="60" as="geometry"/></mxCell><mxCell id="sec_data" value="1. CDC 데이터 처리 흐름" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="40" y="110" width="1180" height="230" as="geometry"/></mxCell><mxCell id="oracle" value="Oracle Source DB&lt;br&gt;Redo / Archive Log" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="80" y="190" width="150" height="70" as="geometry"/></mxCell><mxCell id="connect" value="Kafka Connect Cluster&lt;br&gt;&lt;b&gt;Connector 실행 런타임&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="300" y="170" width="200" height="110" as="geometry"/></mxCell><mxCell id="debezium" value="Debezium Oracle&lt;br&gt;Source Connector Task&lt;br&gt;&lt;br&gt;Oracle 변경 로그 읽기&lt;br&gt;CDC 이벤트 생성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="540" y="165" width="210" height="120" as="geometry"/></mxCell><mxCell id="kafka" value="Strimzi Kafka Cluster&lt;br&gt;Kafka 3.9.0 / KRaft&lt;br&gt;&lt;br&gt;CDC Topic&lt;br&gt;Connect Internal Topic&lt;br&gt;Schema History Topic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="790" y="150" width="220" height="150" as="geometry"/></mxCell><mxCell id="sink" value="PostgreSQL Sink / Consumer&lt;br&gt;Kafka Topic 구독&lt;br&gt;Target 반영" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1050" y="170" width="150" height="110" as="geometry"/></mxCell><mxCell id="pg" value="PostgreSQL&lt;br&gt;Target DB" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1260" y="190" width="150" height="70" as="geometry"/></mxCell><mxCell id="e_oracle_connect" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="oracle" target="connect"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_connect_debezium" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="connect" target="debezium"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_debezium_kafka" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="debezium" target="kafka"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_kafka_sink" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="kafka" target="sink"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_sink_pg" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="sink" target="pg"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="note_connect" value="주의: Debezium Connector가 Kafka Connect로 메시지를 전달하는 구조가 아닙니다.&lt;br&gt;Debezium Connector는 Kafka Connect 내부에서 실행되며 Kafka Topic으로 CDC 이벤트를 발행합니다." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="300" y="290" width="450" height="40" as="geometry"/></mxCell><mxCell id="sec_gitops" value="2. Argo CD / GitOps 배포 흐름" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="40" y="380" width="1180" height="260" as="geometry"/></mxCell><mxCell id="devops" value="DevOps Repository&lt;br&gt;&lt;br&gt;1) Strimzi Helm Chart&lt;br&gt;2) Kafka 플랫폼 CR&lt;br&gt;3) Kustomize 구성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="80" y="465" width="210" height="120" as="geometry"/></mxCell><mxCell id="connector_repo" value="Connector Repository&lt;br&gt;&lt;br&gt;KafkaConnector&lt;br&gt;Debezium 설정&lt;br&gt;Kustomize 구성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="80" y="610" width="210" height="100" as="geometry"/></mxCell><mxCell id="argo_operator" value="Argo CD App&lt;br&gt;Strimzi Operator&lt;br&gt;&lt;b&gt;Helm&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="390" y="445" width="180" height="90" as="geometry"/></mxCell><mxCell id="argo_platform" value="Argo CD App&lt;br&gt;Kafka Platform CR&lt;br&gt;&lt;b&gt;Kustomize&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="390" y="555" width="180" height="90" as="geometry"/></mxCell><mxCell id="argo_connector" value="Argo CD App&lt;br&gt;CDC Connector&lt;br&gt;&lt;b&gt;Kustomize&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="390" y="665" width="180" height="90" as="geometry"/></mxCell><mxCell id="strimzi_op" value="Strimzi Operator&lt;br&gt;CRD / RBAC / Deployment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="700" y="445" width="190" height="90" as="geometry"/></mxCell><mxCell id="platform_cr" value="Kafka Platform CR&lt;br&gt;Kafka / KafkaNodePool&lt;br&gt;KafkaConnect / Topic / User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="700" y="555" width="210" height="90" as="geometry"/></mxCell><mxCell id="connector_cr" value="CDC Connector CR&lt;br&gt;KafkaConnector&lt;br&gt;Oracle Source 설정" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1"><mxGeometry x="700" y="665" width="210" height="90" as="geometry"/></mxCell><mxCell id="op_manages" value="Strimzi Operator가 CR을 reconcile 하여 실제 Kubernetes 리소스를 생성/관리합니다." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="970" y="555" width="220" height="90" as="geometry"/></mxCell><mxCell id="e_devops_operator" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="devops" target="argo_operator"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_devops_platform" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="devops" target="argo_platform"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_repo_connector" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="connector_repo" target="argo_connector"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_argo_operator" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="argo_operator" target="strimzi_op"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_argo_platform" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="argo_platform" target="platform_cr"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_argo_connector" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="argo_connector" target="connector_cr"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_operator_platform" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="strimzi_op" target="platform_cr"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_operator_connector" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="strimzi_op" target="connector_cr"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="sec_monitor" value="3. AKHQ 모니터링 흐름" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="40" y="800" width="1180" height="170" as="geometry"/></mxCell><mxCell id="akhq" value="AKHQ&lt;br&gt;Kafka 운영 / 모니터링 UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1"><mxGeometry x="140" y="860" width="210" height="80" as="geometry"/></mxCell><mxCell id="akhq_kafka" value="Kafka Cluster 조회&lt;br&gt;Topic / Message / Consumer Group" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="500" y="860" width="260" height="80" as="geometry"/></mxCell><mxCell id="akhq_note" value="AKHQ는 Kafka 상태 확인 도구입니다.&lt;br&gt;Oracle Connector 내부 처리와 PostgreSQL 반영 완료 여부는 별도 확인이 필요합니다." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="880" y="855" width="280" height="90" as="geometry"/></mxCell><mxCell id="e_akhq_kafka" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;dashed=1;" edge="1" parent="1" source="akhq" target="akhq_kafka"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="sec_topics" value="4. Kafka Topic 역할 구분" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="40" y="1010" width="1180" height="190" as="geometry"/></mxCell><mxCell id="topic_cdc" value="CDC Topic&lt;br&gt;&lt;br&gt;Oracle 테이블 변경 이벤트 저장&lt;br&gt;예: &lt;topic.prefix&gt;.&lt;schema&gt;.&lt;table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="100" y="1070" width="260" height="90" as="geometry"/></mxCell><mxCell id="topic_internal" value="Connect Internal Topic&lt;br&gt;&lt;br&gt;connect-offsets&lt;br&gt;connect-configs&lt;br&gt;connect-status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="480" y="1070" width="260" height="90" as="geometry"/></mxCell><mxCell id="topic_schema" value="Schema History Topic&lt;br&gt;&lt;br&gt;Oracle Schema 변경 이력 저장&lt;br&gt;Connector 재시작 시 스키마 복구" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="860" y="1070" width="280" height="90" as="geometry"/></mxCell>
